# Aviation Ape Manager - Environment Variables Template
# Copy this file to .env and update with your actual values

# ===================================
# Node Environment
# ===================================
NODE_ENV=production

# ===================================
# Database Configuration (PostgreSQL)
# ===================================
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://aviation_ape_user:your_secure_password@localhost:5432/aviation_ape

# ===================================
# Session Secret (REQUIRED)
# ===================================
# IMPORTANT: Generate a secure random string with at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_GENERATED_RANDOM_STRING_AT_LEAST_32_CHARACTERS

# ===================================
# Email Configuration (Optional)
# ===================================

# Option 1: SMTP (e.g., Gmail, custom SMTP server)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@yourdomain.com

# Option 2: SendGrid (alternative to SMTP - comment out SMTP if using this)
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com
# SENDGRID_FROM_NAME=Aviation Ape Manager

# ===================================
# Application URL (used in email links)
# ===================================
# Set to your public domain in production (no trailing slash)
APP_URL=http://localhost:6000

# ===================================
# Internal API Secret (for queue processor endpoint)
# ===================================
# Used to authenticate POST /api/internal/process-email-queue
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=change-this-to-a-random-string

# ===================================
# Server Configuration (Optional)
# ===================================
# PORT=5000
