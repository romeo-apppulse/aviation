# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/aviation_ape_db

# Session Configuration (Generate a secure random string)
SESSION_SECRET=your-super-secure-session-secret-here

# OpenID Connect Configuration (For Replit Auth - can be removed if using different auth)
REPL_ID=your-repl-id-here
ISSUER_URL=https://replit.com/oidc
REPLIT_DOMAINS=yourdomain.com,localhost:5000

# Email Configuration (Optional - for email notifications)
SENDGRID_API_KEY=your-sendgrid-api-key-here

# SMTP Configuration (Alternative to SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Application Configuration
NODE_ENV=production
PORT=5000